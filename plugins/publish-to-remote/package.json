{
  "name": "publish-to-remote",
  "version": "1.0.0",
  "description": "Plugin for publishing EPUB files to Cloudflare R2 and other S3-compatible storage",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "scripts": {
    "dev": "vite --port 8000",
    "build": "tsc && vite build",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.55.9",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.2"
  },
  "seedhtmlPlugin": {
    "id": "publish-to-remote",
    "name": "Publish to Remote",
    "presentation": "view",
    "buildEntry": "dist/plugin.html"
  },
  "keywords": [
    "epub",
    "cloudflare",
    "r2",
    "s3",
    "opfs",
    "plugin"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@likecoin/epubcheck-ts": "^0.3.0",
    "aws4fetch": "^1.0.20",
    "paneforge": "^1.0.0",
    "phosphor-svelte": "^3.1.0"
  }
}
