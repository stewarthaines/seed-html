{
  "id": "abc2svg+jsyaml",
  "name": "abc2svg+jsyaml",
  "description": "Render ABC music notation code blocks as SVG scores with abc2svg, engraved with the Bravura font; js-yaml reads each block's frontmatter options. Pre-rendered scale variants switch to fit the reading column.",
  "category": "code-blocks",
  "url": "https://chiselapp.com/user/moinejf/repository/abc2svg/doc/trunk/README.md",
  "license": "LICENSE.txt",
  "assets": [
    {
      "file": "themes/Bravura.woff2",
      "target": "Fonts/Bravura.woff2",
      "media": "application/font-woff"
    },
    {
      "file": "themes/font.css",
      "target": "Styles/abc-font.css",
      "media": "text/css"
    },
    {
      "file": "abc2svg.css",
      "target": "Styles/abc2svg.css",
      "media": "text/css"
    }
  ],
  "scripts": [
    "abc2svg-1.js",
    "js-yaml.min.js"
  ],
  "generators": [
    {
      "id": "abc-sample",
      "name": "ABC Sample",
      "description": "Insert a sample of ABC notation with yaml frontmatter specifying rendering options.",
      "script": "abc-sample.js",
      "options": [
        {
          "type": "select",
          "name": "format",
          "label": "Plain text wrapper",
          "default": "markdown",
          "options": [
            {
              "value": "markdown",
              "label": "Markdown"
            },
            {
              "value": "textile",
              "label": "Textile"
            }
          ]
        },
        {
          "type": "boolean",
          "name": "include_scales",
          "label": "Include multiple scale classes",
          "default": false
        },
        {
          "type": "boolean",
          "name": "multiple_voices",
          "label": "Include three voices",
          "default": false
        }
      ]
    }
  ],
  "domTransforms": [
    "transformABC.js"
  ],
  "textTransforms": []
}
