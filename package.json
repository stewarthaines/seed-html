{
  "name": "editme-svelte",
  "private": true,
  "version": "0.4.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run i18n:build && vite build",
    "build:dev": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test:stories": "vitest run --config .storybook/vitest.config.ts",
    "screenshots": "node scripts/capture-screenshots.js",
    "worktree": "bash scripts/new-worktree.sh",
    "lint": "eslint . --ext .js,.ts,.svelte",
    "lint:fix": "eslint . --ext .js,.ts,.svelte --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:extract": "node build-scripts/i18n-extract.js",
    "i18n:convert": "node build-scripts/i18n-convert.js",
    "i18n:compress": "node build-scripts/i18n-compress.js",
    "i18n:build": "npm run i18n:extract && npm run i18n:convert && npm run i18n:compress",
    "translate:demo": "node scripts/auto-translate.js",
    "translate:populate": "node scripts/populate-demo-translations.js",
    "analyze": "npm run build && open dist/stats.html",
    "opds:install": "cd opds-server && npm install",
    "opds:serve": "cd opds-server && npm start",
    "opds:dev": "cd opds-server && npm run dev"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.0",
    "@eslint/js": "^9.29.0",
    "@storybook/addon-a11y": "^9.0.5",
    "@storybook/addon-docs": "^9.0.5",
    "@storybook/addon-svelte-csf": "^5.0.3",
    "@storybook/addon-themes": "^9.0.14",
    "@storybook/addon-vitest": "^9.0.5",
    "@storybook/svelte-vite": "^9.0.5",
    "@storybook/test": "^9.0.0-alpha.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/jest-image-snapshot": "^6.4.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/browser": "^3.2.2",
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.29.0",
    "eslint-plugin-svelte": "^3.9.3",
    "fflate": "^0.8.2",
    "gettext-extractor": "^3.8.0",
    "gettext-parser": "^8.0.0",
    "happy-dom": "^18.0.1",
    "jest-image-snapshot": "^6.5.1",
    "playwright": "^1.52.0",
    "po2json": "^0.4.5",
    "prettier": "^3.6.0",
    "prettier-plugin-svelte": "^3.4.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "storybook": "^9.0.5",
    "svelte": "^5.28.1",
    "svelte-check": "^4.1.6",
    "svelte-eslint-parser": "^1.2.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-checker": "^0.10.3",
    "vite-plugin-singlefile": "^2.2.0",
    "vitest": "^3.2.2"
  },
  "dependencies": {
    "paneforge": "^1.0.0"
  }
}
