{
  "name": "editme-svelte",
  "private": true,
  "version": "0.5.1",
  "type": "module",
  "workspaces": [
    "plugins/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:i18n": "npm run i18n:build && vite build",
    "build:plugins": "npm run build --workspaces --if-present && node scripts/generate-plugin-manifest.js && node scripts/generate-extensions-manifest.js",
    "build:extensions": "node scripts/generate-extensions-manifest.js",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist --project-name readitinabook --branch main",
    "smoke": "node scripts/smoke-build.js",
    "check": "svelte-check --tsconfig ./tsconfig.app.json --fail-on-warnings && tsc -p tsconfig.node.json && tsc -p functions/tsconfig.json",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test:stories": "vitest run --config .storybook/vitest.config.ts",
    "test:plugins": "vitest run --config vitest.config.plugins.ts",
    "screenshots": "node scripts/capture-screenshots.js",
    "test:a11y": "node scripts/a11y-scan.mjs",
    "worktree": "bash scripts/new-worktree.sh",
    "lint": "eslint . --ext .js,.ts,.svelte --max-warnings 312",
    "lint:fix": "eslint . --ext .js,.ts,.svelte --fix",
    "validate": "npm run check && npm run lint && npm run format:check && npm run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:extract": "node build-scripts/i18n-extract.js",
    "i18n:convert": "node build-scripts/i18n-convert.js",
    "i18n:compress": "node build-scripts/i18n-compress.js",
    "i18n:build": "npm run i18n:extract && npm run i18n:convert && npm run i18n:compress",
    "lint:i18n": "node scripts/i18n-lint.mjs",
    "translate:demo": "node scripts/auto-translate.js",
    "translate:populate": "node scripts/populate-demo-translations.js",
    "analyze": "ANALYZE=1 vite build && open dist/stats.html"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/storybook": "^4.0.0",
    "@eslint/js": "^9.29.0",
    "@storybook/addon-a11y": "~9.0.14",
    "@storybook/addon-docs": "~9.0.14",
    "@storybook/addon-svelte-csf": "^5.0.3",
    "@storybook/addon-themes": "~9.0.14",
    "@storybook/addon-vitest": "~9.0.14",
    "@storybook/svelte-vite": "~9.0.14",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/jest-image-snapshot": "^6.4.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/browser": "^3.2.2",
    "@vitest/coverage-v8": "^3.2.2",
    "eslint": "^9.29.0",
    "eslint-plugin-svelte": "^3.9.3",
    "fflate": "^0.8.2",
    "gettext-extractor": "^3.8.0",
    "gettext-parser": "^8.0.0",
    "happy-dom": "^18.0.1",
    "jest-image-snapshot": "^6.5.1",
    "playwright": "^1.52.0",
    "po2json": "^0.4.5",
    "prettier": "^3.6.0",
    "prettier-plugin-svelte": "^3.4.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "storybook": "~9.0.14",
    "svelte": "^5.55.9",
    "svelte-check": "^4.1.6",
    "svelte-eslint-parser": "^1.2.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-checker": "^0.10.3",
    "vite-plugin-singlefile": "^2.2.0",
    "vitest": "^3.2.2",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "paneforge": "^1.0.0",
    "phosphor-svelte": "^3.1.0"
  }
}
